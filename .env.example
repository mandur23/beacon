# Beacon 필수 환경변수 예시. 복사 후 .env 로 저장하고 실제 값을 채우세요.
# .env 는 .gitignore 에 의해 버전 관리에서 제외됩니다.

# ── HTTP/HTTPS ────────────────────────────────────────────────
# true(기본): https://localhost:8080 | false: http://localhost:8080
SERVER_SSL_ENABLED=true
# PKCS12 경로를 외부 파일로 바꾸려면 지정 (예: C:\certs\beacon-prod.p12)
# SERVER_SSL_KEYSTORE_PATH=classpath:keystore.p12
# mkcert -pkcs12 로 만든 keystore 기본 비밀번호는 changeit
# SERVER_SSL_KEYSTORE_PASSWORD=changeit
# mkcert가 만든 PKCS12의 기본 alias는 1
# SERVER_SSL_KEY_ALIAS=1
# PEM 인증서 사용 시 둘 다 지정 (예: Let's Encrypt)
# SERVER_SSL_CERTIFICATE=/etc/letsencrypt/live/example.com/fullchain.pem
# SERVER_SSL_CERTIFICATE_PRIVATE_KEY=/etc/letsencrypt/live/example.com/privkey.pem

# ── 데이터베이스 ──────────────────────────────────────────────
BEACON_DB_URL=jdbc:mysql://localhost:3306/beacon?serverTimezone=Asia/Seoul&characterEncoding=UTF-8
BEACON_DB_USERNAME=root
BEACON_DB_PASSWORD=your_db_password_here
# 동시 요청·롱폴·폴링 대비 (기본 25). 풀 고갈 시 30~50까지 조정
# BEACON_DB_POOL_SIZE=25
# 개발 중 연결 누수 의심 시 60000 등으로 설정 (운영에서는 0 권장)
# BEACON_DB_LEAK_DETECTION_MS=0

# ── JWT ───────────────────────────────────────────────────────
# HS256: 최소 32바이트 문자열 (짧은 값·숫자만 있으면 앱 기동 실패)
# 생성 예: openssl rand -base64 48
BEACON_JWT_SECRET=change_this_to_secure_random_string_min_32_bytes
BEACON_JWT_EXPIRATION=86400000

# ── ML 서비스 ─────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:5000

# ── AI (Ollama) ───────────────────────────────────────────────
# 로컬 Ollama 실행(비 Docker). 서버 부트스트랩 시 자동 설치를 허용.
OLLAMA_DOCKER_ENABLED=false
OLLAMA_DOCKER_AUTO_START=false
OLLAMA_AUTO_INSTALL=true
OLLAMA_ALLOW_AUTO_INSTALL=true
# 모델 저장 위치는 실행 셸 환경변수 OLLAMA_MODELS(예: .runtime/ollama)로 지정 가능

# ── Suricata ──────────────────────────────────────────────────
SURICATA_EVE_ENABLED=false
SURICATA_EVE_PATH=C:\Program Files\Suricata\log\eve.json
SURICATA_EVE_POLL_MS=500

# ── Syslog ────────────────────────────────────────────────────
SYSLOG_PORT=514

# ── 로그 레벨 ─────────────────────────────────────────────────
LOG_LEVEL_APP=INFO
LOG_LEVEL_SECURITY=WARN
